{
  "name": "family-business-maturity-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node --use-system-ca server/index.js",
    "build": "vite build",
    "verify": "node --check server/airtable.js && node --check server/email.js && node --check server/summary-report.js && node --check server/index.js && node --check api/results.js && node --check api/groups.js && node --check api/invitations.js && node --check api/summary-pdf.js && npm run verify:config && npm run verify:lockfile && npm run verify:ui && npm run verify:airtable && npm run verify:api && npm run verify:serverless && npm run build",
    "verify:config": "node scripts/verify-config.mjs",
    "verify:lockfile": "node scripts/verify-lockfile.mjs",
    "verify:api": "node scripts/verify-api-routes.mjs",
    "verify:airtable": "node scripts/verify-airtable-persistence.mjs",
    "verify:ui": "node scripts/verify-ui-copy.mjs",
    "verify:serverless": "node scripts/verify-serverless-handlers.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "libphonenumber-js": "^1.13.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.12"
  }
}
